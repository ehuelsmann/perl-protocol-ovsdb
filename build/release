#!/usr/bin/bash

set -euo pipefail

if [ -n "$(git status -s)" ]
then
    echo "ERROR: Tree is not clean"
    exit 1
fi

if [ -n "$(git tag --list "$1")" ]
then
    echo "ERROR: Tag $1 exists"
    exit 1
fi

set -x
build/patch-version $1
perl Makefile.PL
make manifest
make dist
git tag $1

set +x
cat <<'EOF'

DONE: Release created succesfully

run 'git checkout lib' to undo changes made by the release process
EOF
